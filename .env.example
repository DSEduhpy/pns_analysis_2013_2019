# Configurações do projeto PNS Analysis
# Copie este arquivo para .env e preencha com seus valores

# ID do projeto de billing do Google Cloud para consultas no BigQuery
# Este é o projeto que será cobrado pelas queries executadas
# Nível de log (opcional, padrão: INFO)
# Valores possíveis: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=DEBUG
